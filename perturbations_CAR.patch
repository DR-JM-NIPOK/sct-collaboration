+/* CAR modification — Codified Acoustic Relation sound speed (v4.8.1)
+ * Original: cs2 = 1.0 / (3.0 * (1.0 + R))    standard ΛCDM, R = 3·ρ_b/(4·ρ_γ)
+ * CAR    : cs2 = (1.0 + R_b(z)) / 3.0        R_b = R_B_DERIVED/(1+z)
+ *
+ * Critical: R_b ≠ R. R_b is the SCT-derived coherence ratio (Paper 17
+ * v4.8 §11.6), NOT the density ratio. R_B_DERIVED = 0.2545.
+ * Do NOT reuse CLASS's pvecthermo[index_th_R] in the CAR formula —
+ * that is the density ratio and gives superluminal cs² at low z.
+ * Reference: NIPOK, SCT Cosmology Series Paper #16,
+ *            DOI: 10.13140/RG.2.2.10321.29288
+ */

 /* In function perturb_derivs(), find the baryon-photon sound speed line: */
 /* Standard CLASS:                                                         */
-  cs2 = 1.0 / (3.0 * (1.0 + R));
+
+  /* ── CAR canonical master equation (v4.8.1) ──────────────────────── */
+  /* R_B_DERIVED = 0.2545 from Paper 17 v4.8 §11.6                        */
+  /* z is the redshift at this thermodynamics step (CLASS provides it)    */
+  {
+    const double R_B_DERIVED_CAR = 0.2545;
+    double R_b_CAR = R_B_DERIVED_CAR / (1.0 + z);
+    cs2 = (1.0 + R_b_CAR) / 3.0;
+  }
+  /* ───────────────────────────────────────────────────────────────────── */

 /* Note: CLASS's pvecthermo[index_th_R] (the standard density ratio R)    */
 /* is still computed and used elsewhere (recombination, momentum coupling */
 /* — DO NOT replace those uses. Only cs2 changes to use the CAR formula  */
 /* with the SCT-derived coherence ratio R_b ≠ R.                          */

